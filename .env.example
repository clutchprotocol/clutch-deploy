# Clutch Deploy - Environment Configuration
# Copy to .env and update values

# Seq (optional - for structured logging)
SEQ_API_KEY=
SEQ_ADMIN_USERNAME=admin
SEQ_ADMIN_PASSWORD=seq-admin-password

# JWT (if API requires)
JWT_SECRET=your-super-secret-jwt-key-here

# CORS - allowed origins for API (comma-separated). Include your stage demo origin, e.g.:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://app-stage.clutchprotocol.io
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://app-stage.clutchprotocol.io

# Explorer
EXPLORER_ALLOWED_ORIGINS=*
EXPLORER_POSTGRES_DB=clutch_explorer
EXPLORER_POSTGRES_USER=postgres
EXPLORER_POSTGRES_PASSWORD=postgres
